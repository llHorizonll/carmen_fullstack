# Carmen Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================
# Database (MySQL)
# ============================================
MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_PASSWORD=change-me-app-password

# ============================================
# Authentication (JWT)
# ============================================
# Must be at least 32 characters long
JWT_SECRET=change-me-jwt-secret-at-least-32-characters

# ============================================
# Application
# ============================================
ASPNETCORE_ENVIRONMENT=Production

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=http://localhost:3000

# ============================================
# jsreport (Report Designer)
# ============================================
JSREPORT_PASSWORD=change-me-jsreport-password

# ============================================
# SMTP (Email - Optional)
# ============================================
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM=noreply@carmen.com

# ============================================
# External Integrations (Optional)
# ============================================
# BLUELEDGER_API_URL=https://blueledger.example.com/api
# BLUELEDGER_API_KEY=your-api-key
# MISTRAL_API_KEY=your-mistral-api-key
