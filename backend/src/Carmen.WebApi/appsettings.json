{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Port=3306;Database=Carmen;Uid=carmen_user;Pwd=your_password;SslMode=Preferred;"
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "Jwt": {
    "SecretKey": "carmen-secret-key-at-least-32-characters-long",
    "Issuer": "Carmen",
    "Audience": "CarmenUsers",
    "ExpiryMinutes": 480
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  },
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.Hosting.Lifetime": "Information",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/carmen-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": ["FromLogContext", "WithMachineName", "WithProcessId"]
  },
  "BlueLedger": {
    "Enabled": true,
    "BaseUrl": "https://blueledger.example.com/api",
    "ApiKey": "",
    "Timeout": 30
  },
  "Mistral": {
    "ApiKey": "",
    "OcrUrl": "https://api.mistral.ai/v1/ocr",
    "ChatUrl": "https://api.mistral.ai/v1/chat/completions",
    "ChatModel": "mistral-large-latest"
  },
  "Smtp": {
    "Host": "",
    "Port": 587,
    "FromEmail": "noreply@carmen.com",
    "FromName": "Carmen",
    "Username": "",
    "Password": "",
    "UseSsl": true
  },
  "AllowedHosts": "*"
}
